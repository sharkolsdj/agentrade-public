# AgenTrade — Environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Interactive Brokers ────────────────────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497                      # 7497 = paper trading, 7496 = live
IB_ACCOUNT=YOUR_IB_PAPER_ACCOUNT  # e.g. DU1234567
IB_CLIENT_ID_EXEC=11              # executor clientId
IB_CLIENT_ID_DATA=96              # dedicated datafeed clientId (IBDataFeed)
IB_CLIENT_ID_DATA_1=95            # datafeed failover clientId 1
IB_CLIENT_ID_DATA_2=94            # datafeed failover clientId 2

# ── MT4 / DWX ZeroMQ ──────────────────────────────────────────────────────────
MT4_HOST=localhost
MT4_PUSH_PORT=32768               # EA → Python (orders)
MT4_PULL_PORT=32769               # Python → EA (commands)
MT4_SUB_PORT=32770                # EA → Python (market data subscription)

# MT4 data EAs (multi-EA setup — optional, fallback to EA1 if not set)
MT4_DATA_FOREX_PUSH_PORT=32780    # EA2 forex datafeed
MT4_DATA_FOREX_PULL_PORT=32781
MT4_DATA_CRYPTO_PUSH_PORT=32782   # EA3 crypto datafeed
MT4_DATA_CRYPTO_PULL_PORT=32783
MT4_DATA_METALS_PUSH_PORT=32784   # EA4 metals+indices datafeed
MT4_DATA_METALS_PULL_PORT=32785

# ── LLM APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY    # MacroAgent (Claude Sonnet) + StrategyRAGAgent (Claude Haiku)
OPENAI_API_KEY=YOUR_OPENAI_KEY          # SentimentAgent (GPT-4o-mini)

# ── FRED API (macro data) ─────────────────────────────────────────────────────
FRED_API_KEY=YOUR_FRED_API_KEY          # Free at https://fred.stlouisfed.org/docs/api/api_key.html

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_ai
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# Convenience URL (overrides individual vars if set)
# DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/trading_ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ── Vector DB (Qdrant) ────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=trading_strategies    # collection name for strategy KB

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Risk parameters (example values — set your own) ────────────────────────────
PAPER_EQUITY_USD=10000.0                # paper account equity in USD (example)
RISK_PER_TRADE_PCT=1.0                  # % equity risked per trade (example)
MAX_DRAWDOWN_PCT=10.0                   # maximum tolerated drawdown % (example)
MAX_OPEN_MT4=5                          # max simultaneous MT4 positions (example)
MAX_OPEN_IB=3                           # max simultaneous IB positions (example)

# ── Execution thresholds ──────────────────────────────────────────────────────
AUTO_EXECUTE_THRESHOLD=85.0             # consensus ≥ this → auto-execute
MANUAL_THRESHOLD=60.0                   # consensus ≥ this → Telegram approval

# ── IB Micro risk caps (example values — set your own) ─────────────────────────
IB_MICRO_WARN_RISK_USD=250.0            # soft cap — trade approved with warning (example)
IB_MICRO_MAX_RISK_USD=500.0             # hard cap — trade blocked (example)
